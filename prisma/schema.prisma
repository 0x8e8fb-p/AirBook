generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public", "auth"]
}

model FlightRoute {
  id          String   @id @default(cuid())
  origin      String
  destination String
  prices      PriceHistory[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([origin, destination])
  @@schema("public")
}

model PriceHistory {
  id             String      @id @default(cuid())
  routeId        String
  route          FlightRoute @relation(fields: [routeId], references: [id])
  departureDate  DateTime
  effectivePrice Float
  basePrice      Float
  airline        String
  recordedAt     DateTime    @default(now())

  @@index([routeId, departureDate])
  @@schema("public")
}

// =========================================
// Auth.js (NextAuth) Models
// =========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@schema("public")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@schema("public")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String?   @unique
  mobile        String?   @unique
  dob           DateTime?
  emailVerified DateTime?
  password      String?   // New field for email/password credentials login
  image         String?
  accounts      Account[]
  sessions      Session[]
  
  // Custom AirBook Fields
  savedCards    String?   // JSON string array of bank IDs e.g. '["HDFC", "SBI"]'
  searches      SearchHistory[]
  alerts        PriceAlert[]
  @@schema("public")
}

model PriceAlert {
  id            String   @id @default(cuid())
  userId        String
  origin        String
  destination   String
  targetPrice   Float
  active        Boolean  @default(true)
  lastNotified  DateTime?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@schema("public")
}

model SearchHistory {
  id            String   @id @default(cuid())
  userId        String?
  origin        String
  destination   String
  departureDate DateTime
  returnDate    DateTime?
  passengers    Int      @default(1)
  adults        Int?     @default(1)
  cabinClass    String?
  createdAt     DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@schema("public")
}

model BookingClick {
  id            String   @id @default(cuid())
  userId        String?
  route         String
  airline       String
  price         Float
  discountSaved Float
  createdAt     DateTime @default(now())
  @@schema("public")
}

model PriceFreeze {
  id             String   @id @default(cuid())
  userId         String
  origin         String
  destination    String
  departureDate  DateTime
  airline        String
  flightNumber   String?
  lockedPrice    Float
  basePrice      Float
  expiresAt      DateTime
  redeemed       Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([userId, expiresAt])
  @@schema("public")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@schema("public")
}

model FlightOffer {
  id          String   @id @default(cuid())
  source      String   // "hdfc_smartbuy", "grabon", "manual", etc.
  category    String   // "bank_cc", "bank_dc", "bank_emi", "upi_wallet",
                       // "airline_promo", "ota_coupon", "cashback_portal",
                       // "international", "loyalty", "seasonal"
  bankCode    String?  // "HDFC", "SBI", etc. (null for airline/OTA offers)
  name        String   // Human-readable offer name
  description String?  // Longer description with terms
  type        String   // "percentage" or "flat"
  value       Float    // 0.15 for 15%, or 1500 for flat ₹1500
  maxCap      Float?   // Max discount cap for percentage offers
  minBooking  Float    @default(0)
  promoCode   String?  // "HDFCEMI", "6E400", etc.
  platform    String?  // "makemytrip", "cleartrip", "ixigo", "airline_direct", "any"
  airline     String?  // "6E", "AI", etc. (null = all airlines)
  url         String?  // Link to official offer page
  validFrom   DateTime @default(now())
  validUntil  DateTime
  active      Boolean  @default(true)
  priority    Int      @default(0)
  scrapedAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, validUntil])
  @@index([category, bankCode])
  @@index([platform])
  @@schema("public")
}
