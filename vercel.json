{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["bom1"],
  "crons": [
    {
      "path": "/api/cron/track",
      "schedule": "0 0 * * *"
    }
  ],
  "functions": {
    "src/app/api/cron/track/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/search/route.ts": {
      "maxDuration": 30
    }
  },
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/flights.py",
      "use": "@vercel/python"
    }
  ]
}
