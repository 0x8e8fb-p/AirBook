# -----------------------------------------------------------------------------
# TheWingsScan environment variables
# Copy to .env (local dev) or set in Vercel Project Settings > Environment Variables.
# NEVER commit a populated .env file.
# -----------------------------------------------------------------------------

# --- Supabase (Postgres + Auth helper) -------------------------------------
# Pooled connection used by Prisma runtime. Use the Supabase connection pooler URL.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection used by Prisma for migrations only.
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"
# Public anon key — safe to ship to the browser.
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service-role key — SERVER ONLY. Bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=""

# --- NextAuth ---------------------------------------------------------------
# In production set to the public URL (no trailing slash).
NEXTAUTH_URL="http://localhost:3000"
# 32+ bytes of random entropy. Generate with: openssl rand -base64 48
NEXTAUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Resend (transactional email) ------------------------------------------
# SERVER ONLY. Do not prefix with NEXT_PUBLIC_.
RESEND_API_KEY=""

# --- Travelpayouts / Aviasales ----------------------------------------------
# Server-only affiliate token from Travelpayouts Profile > API token.
TRAVELPAYOUTS_TOKEN=""
# Partner ID / marker from the Travelpayouts dashboard. Required for real-time search and affiliate redirects.
TRAVELPAYOUTS_MARKER=""
# Optional browser-visible marker for generic Aviasales fallback links.
NEXT_PUBLIC_TRAVELPAYOUTS_MARKER=""
# Public production host registered with Travelpayouts. Example: thewingsscan.com
TRAVELPAYOUTS_HOST=""
# Optional override; defaults to https://api.travelpayouts.com.
TRAVELPAYOUTS_API_BASE="https://api.travelpayouts.com"
# Enable only after Aviasales real-time search access is approved.
TRAVELPAYOUTS_ENABLE_REALTIME_SEARCH="false"
# Required only when real-time search is enabled. Must be a public user IP, not localhost.
TRAVELPAYOUTS_DEFAULT_USER_IP=""
# Optional JSON array of partner offers using the app Coupon shape.
TRAVELPAYOUTS_PARTNER_OFFERS_JSON=""

# --- Upstash Redis (cache + rate limit) ------------------------------------
# Optional in local dev; required in production for reasonable cache hit rates.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Vercel Cron --------------------------------------------------------------
# Auto-injected as "Authorization: Bearer $CRON_SECRET" on scheduled invocations.
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# --- Monitoring (optional) -------------------------------------------------
SENTRY_DSN=""

# --- Public site URL (for OG tags, canonical links) ------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
