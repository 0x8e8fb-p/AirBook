# -----------------------------------------------------------------------------
# AirBook environment variables
# Copy to .env (local dev) or set in Vercel Project Settings > Environment Variables.
# NEVER commit a populated .env file.
# -----------------------------------------------------------------------------

# --- Supabase (Postgres + Auth helper) -------------------------------------
# Pooled connection used by Prisma runtime. Use the Supabase connection pooler URL.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection used by Prisma for migrations only.
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"
# Public anon key — safe to ship to the browser.
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service-role key — SERVER ONLY. Bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=""

# --- NextAuth ---------------------------------------------------------------
# In production set to the public URL (no trailing slash).
NEXTAUTH_URL="http://localhost:3000"
# 32+ bytes of random entropy. Generate with: openssl rand -base64 48
NEXTAUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Resend (transactional email) ------------------------------------------
# SERVER ONLY. Do not prefix with NEXT_PUBLIC_.
RESEND_API_KEY=""

# --- AirAPI (sibling fare-aggregator service) ------------------------------
# Base URL (no trailing slash). Example: https://api.airbook.dev
AIRAPI_URL=""
# Issued by the AirAPI admin dashboard (api_keys.client_id).
AIRAPI_CLIENT_ID=""
# Secret paired with the client_id. Rotate quarterly.
AIRAPI_KEY=""

# --- Upstash Redis (cache + rate limit) ------------------------------------
# Optional in local dev; required in production for reasonable cache hit rates.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Monitoring (optional) -------------------------------------------------
SENTRY_DSN=""

# --- Public site URL (for OG tags, canonical links) ------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
